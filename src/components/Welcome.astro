---
import ".././assets/global.css";
import portada from "../assets/Portada.jpg";
import portadaMobile from "../assets/PortadaMobile.jpg";
import Valores from "./Valores.astro";
import Galeria from "./Galerias/Galeria.astro";
import Boda from "./Galerias/Boda.astro";
import Video from "./Video.astro";
import Planes from "./Planes.astro";
import Posters from "./Posters.astro";
import Calculadora from "./Calculadora.astro";
import { Image } from "astro:assets";
---

<div>
  <div>
    <picture>
      <source media="(min-width: 768px)" srcset={portada.src} />
      <Image
        src={portadaMobile}
        class="h-screen w-full object-cover"
        alt="Portada Makers"
        loading="eager"
        priority
      />
    </picture>
    <div class="flex relative">
      <div class="w-1/3 absolute bottom-20 left-20 text-[#cacaca]">
        <h1 class="text-2xl font-extrabold">MAKERS</h1>
        <p class="sm:text-lg">
          Cada momento es único, nosotros lo hacemos eterno.
        </p>
      </div>
    </div>
  </div>

  <Valores />

  <Video />

  <section
    id="aboutUs"
    class="text-center bg-[#111111] text-[#cacaca] flex flex-col justify-center items-center mb-20 md:px-80 sm:px-20 px-10 mt-20"
  >
    <div class="mb-12 max-w-3xl">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">¿Quiénes somos?</h1>

      <p class="text-lg leading-relaxed">
        Somos fotógrafos apasionados por capturar momentos que cuentan
        historias. Nos especializamos en sesiones creativas que van más allá de
        una simple imagen, buscando reflejar la esencia, personalidad y emoción
        de cada persona.
        <br /><br />
        Originarios de Felipe Carrillo Puerto, Quintana Roo, trabajamos con una visión
        clara: transformar ideas en recuerdos visuales únicos.
      </p>
    </div>

    <div class="flex flex-col md:flex-row gap-10 max-w-4xl">
      <div class="md:w-1/2 md:text-right">
        <h2 class="text-2xl font-bold mb-3">Misión</h2>
        <p class="leading-relaxed">
          Evolucionar en cada proyecto, superándonos constantemente en
          creatividad, técnica y calidad, ofreciendo un servicio accesible sin
          perder el valor artístico que nos define.
        </p>
      </div>

      <div class="md:w-1/2 md:text-left">
        <h2 class="text-2xl font-bold mb-3">Visión</h2>
        <ul class="space-y-2">
          <li>Convertirnos en un estudio fotográfico consolidado.</li>
          <li>Destacar por nuestra composición, estilo y calidad visual.</li>
          <li>
            Ser reconocidos como referentes de la fotografía en la península.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="w-full text-[#cacaca]">
    <!-- BOTONES -->
    <div class="flex flex-col md:flex-row justify-center gap-5 mb-10">
      <button
        class="tab-btn active hover:border-b-2 hover:border-[#f95602] text-3xl font-bold transition-all duration-500"
        data-tab="galeria">PRINCIPAL</button
      >
      <button
        class="tab-btn hover:border-b-2 hover:border-[#f95602] text-3xl font-bold transition-all duration-500"
        data-tab="boda">BODA</button
      >
      <button
        class="tab-btn hover:border-b-2 hover:border-[#f95602] text-3xl font-bold transition-all duration-500"
        data-tab="xv">XV AÑOS</button
      >
      <button
        class="tab-btn hover:border-b-2 hover:border-[#f95602] text-3xl font-bold transition-all duration-500"
        data-tab="infantiles">INFANTILES</button
      >
    </div>

    <!-- CONTENIDO -->
    <div>
      <div id="galeria" class="tab-content">
        <Galeria />
      </div>

      <div id="boda" class="tab-content hidden">
        <Boda />
      </div>

      <div id="xv" class="tab-content hidden">
        <div class="text-center">
          <h1 class="font-bold text-4xl text-[#f95602]">PRÓXIMAMENTE...</h1>
          <p>
            Si quieres ver algunos ejemplos de fotos de XV años no olvides
            visitar nuestras redes sociales.
          </p>
        </div>
      </div>
      <div id="infantiles" class="tab-content hidden">
        <div class="text-center">
          <h1 class="font-bold text-4xl text-[#f95602]">PRÓXIMAMENTE...</h1>
          <p>
            Si quieres ver algunos ejemplos de fotos infantiles este pendiente
            de nuestras redes sociales.
          </p>
        </div>
      </div>
    </div>

    <div
      id="modal"
      class="fixed inset-0 bg-black/70 backdrop-blur-xl hidden items-center justify-center z-50"
    >
      <img
        id="modalImg"
        class="max-w-[90%] max-h-[90%] rounded-xl border border-white/10 shadow-2xl transition-transform duration-300 scale-95"
      />
    </div>
  </section>

  <Posters />

  <section class="text-[#cacaca] justify-center content-center">
    <div class="flex flex-col lg:flex-row lg:px-20 md:px-10 px-5">
      <div class="lg:mr-10">
        <div class="mb-5">
          <h1 class="text-6xl font-bold">¿Te gusta nuestro trabajo?</h1>
        </div>
        <div>
          <p>
            Contáctenos para cotizar tu sesión de fotos y volverla inolvidable,
            todos merecen en un momento alguna sesión de fotos inolvidable, <span
              class="font-bold">vive con nosotros la experiencia</span
            >.
          </p>
        </div>
      </div>

      <div class="lg:ml-10 mt-10">
        <Planes />
      </div>
    </div>
  </section>

  <section class="h-screen justify-center content-center">
    <Calculadora />
  </section>
</div>

<script is:inline>
  const buttons = document.querySelectorAll(".tab-btn");
  const contents = document.querySelectorAll(".tab-content");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.tab;

      // quitar activos
      buttons.forEach((b) => b.classList.remove("active"));
      contents.forEach((c) => c.classList.add("hidden"));

      // activar seleccionado
      btn.classList.add("active");
      document.getElementById(target).classList.remove("hidden");
    });
  });
</script>

<script is:inline>
  const modal = document.getElementById("modal");
  const modalImg = document.getElementById("modalImg");

  document.querySelectorAll(".card").forEach((card) => {
    const img = card.querySelector("img");

    // EFECTO 3D (lo de antes)
    card.addEventListener("mousemove", (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      const centerX = rect.width / 2;
      const centerY = rect.height / 2;

      const rotateX = -(y - centerY) / 15;
      const rotateY = (x - centerX) / 15;

      img.style.transform = `
        rotateX(${rotateX}deg)
        rotateY(${rotateY}deg)
        scale(0.96)
      `;
    });

    card.addEventListener("mouseleave", () => {
      img.style.transform = `
        rotateX(0deg)
        rotateY(0deg)
        scale(1)
      `;
    });

    // CLICK → abrir modal
    card.addEventListener("click", () => {
      modal.classList.remove("hidden");
      modal.classList.add("flex");

      modalImg.src = img.src;

      setTimeout(() => {
        modalImg.classList.remove("scale-95");
        modalImg.classList.add("scale-100");
      }, 10);
    });
  });

  // 👇 cerrar al hacer click fuera
  modal.addEventListener("click", () => {
    modalImg.classList.remove("scale-100");
    modalImg.classList.add("scale-95");

    setTimeout(() => {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }, 200);
  });
</script>
